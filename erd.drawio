      <mxCell id="e_uu" value="Admin creates" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.3;exitPerimeter=0;entryX=0;entryY=0;entryPerimeter=0;startArrow=ERmandOne;startFill=0;endArrow=ERmany;endFill=0;" edge="1" source="u_f" target="u_f" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="10" y="210"/><mxPoint x="10" y="140"/><mxPoint x="155" y="140"/><mxPoint x="155" y="194"/></Array></mxGeometry></mxCell>
