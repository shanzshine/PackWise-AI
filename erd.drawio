      <mxCell id="bb_f" value="PK  box_id      INT&#xa;FK  plan_id     INT&#xa;     joint_type  ENUM&#xa;     x           FLOAT&#xa;     y           FLOAT&#xa;     width       FLOAT&#xa;     height      FLOAT&#xa;     source      ENUM&#xa;     created_at  DATETIME" style="text;html=0;strokeColor=#9673a6;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=8;overflow=hidden;fontSize=11;fontFamily=Courier New;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="1"><mxGeometry x="840" y="244" width="260" height="198" as="geometry"/></mxCell>

