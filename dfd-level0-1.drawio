<mxfile host="app.diagrams.net">
  <diagram id="dfd0" name="DFD Level 0 – Context Diagram">
    <mxGraphModel pageWidth="950" pageHeight="700"><root>
      <mxCell id="0"/><mxCell id="1" parent="0"/>
      <mxCell id="sys" value="0&#xa;PackWise AI System" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="325" y="270" width="260" height="120" as="geometry"/></mxCell>
      <mxCell id="e_admin" value="Admin" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="60" width="130" height="50" as="geometry"/></mxCell>
      <mxCell id="e_pe" value="Packing Engineer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="560" width="150" height="50" as="geometry"/></mxCell>
      <mxCell id="e_pm" value="Product Manager" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="730" y="60" width="150" height="50" as="geometry"/></mxCell>
      <mxCell id="e_ai" value="YOLO AI Model" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="730" y="560" width="140" height="50" as="geometry"/></mxCell>
      <mxCell id="f1" value="User data, role assignment" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="e_admin" target="sys" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="f2" value="Confirmation, reports" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="sys" target="e_admin" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="f3" value="Login, plan data, prototype photo, adjustments" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="e_pe" target="sys" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="f4" value="AI results, cost estimation, approval status" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="sys" target="e_pe" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="f5" value="Login, approval decision, revision notes" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="e_pm" target="sys" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="f6" value="Pending plans, plan details, reports" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="sys" target="e_pm" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="f7" value="Detection results (joint targets)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="e_ai" target="sys" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="f8" value="Prototype image" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="sys" target="e_ai" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    </root></mxGraphModel>
  </diagram>

