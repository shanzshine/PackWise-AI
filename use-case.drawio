<mxfile host="app.diagrams.net">
  <diagram id="ucd" name="Use Case Diagram – PackWise AI">
    <mxGraphModel pageWidth="1200" pageHeight="900"><root>
      <mxCell id="0"/><mxCell id="1" parent="0"/>

      <!-- SYSTEM BOUNDARY -->
      <mxCell id="sys" value="PackWise AI System" style="rounded=0;fillColor=none;strokeColor=#333333;strokeWidth=2;verticalAlign=top;fontSize=14;fontStyle=1;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="140" y="30" width="840" height="820" as="geometry"/></mxCell>

      <!-- ACTORS -->
      <mxCell id="ac_admin" value="Admin" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="30" y="230" width="40" height="70" as="geometry"/></mxCell>
      <mxCell id="ac_pe" value="Packing&#xa;Engineer" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="30" y="530" width="40" height="70" as="geometry"/></mxCell>
      <mxCell id="ac_pm" value="Product&#xa;Manager" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1050" y="380" width="40" height="70" as="geometry"/></mxCell>
      <mxCell id="ac_ai" value="YOLO AI&#xa;System" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1050" y="200" width="40" height="70" as="geometry"/></mxCell>

      <!-- USE CASES: Auth -->
      <mxCell id="uc1" value="Log In" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="430" y="65" width="140" height="40" as="geometry"/></mxCell>
      <mxCell id="uc2" value="Change Password" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="625" y="65" width="165" height="40" as="geometry"/></mxCell>

      <!-- USE CASES: Admin -->
      <mxCell id="uc3" value="Create User Account" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="155" y="180" width="185" height="40" as="geometry"/></mxCell>
      <mxCell id="uc4" value="Assign User Role" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="155" y="245" width="165" height="40" as="geometry"/></mxCell>
      <mxCell id="uc5" value="Reset User Password" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="155" y="310" width="185" height="40" as="geometry"/></mxCell>
      <mxCell id="uc6" value="Configure System Settings" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="155" y="375" width="200" height="40" as="geometry"/></mxCell>

      <!-- USE CASES: PE Workflow -->
      <mxCell id="uc7" value="Create Packaging Plan" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="160" width="190" height="40" as="geometry"/></mxCell>
      <mxCell id="uc8" value="Upload Prototype Photo" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="230" width="190" height="40" as="geometry"/></mxCell>
      <mxCell id="uc9" value="Fill Plan Metadata" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="300" width="175" height="40" as="geometry"/></mxCell>
      <mxCell id="uc10" value="Review AI Detection Results" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="390" width="210" height="40" as="geometry"/></mxCell>
      <mxCell id="uc11" value="Adjust Bounding Boxes" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="460" width="190" height="40" as="geometry"/></mxCell>
      <mxCell id="uc12" value="Submit Plan for Approval" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="550" width="200" height="40" as="geometry"/></mxCell>
      <mxCell id="uc13" value="View Plan Status" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="620" width="160" height="40" as="geometry"/></mxCell>
      <mxCell id="uc14" value="Revise &amp; Resubmit Plan" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="690" width="185" height="40" as="geometry"/></mxCell>

      <!-- USE CASES: AI System -->
      <mxCell id="uc15" value="Detect Joint Targets" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="160" width="175" height="40" as="geometry"/></mxCell>
      <mxCell id="uc16" value="Generate Bounding Boxes" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="240" width="195" height="40" as="geometry"/></mxCell>
      <mxCell id="uc17" value="Calculate Cost Estimation" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="320" width="195" height="40" as="geometry"/></mxCell>

      <!-- USE CASES: PM -->
      <mxCell id="uc18" value="View Pending Approvals" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="460" width="190" height="40" as="geometry"/></mxCell>
      <mxCell id="uc19" value="Review Plan Details" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="530" width="175" height="40" as="geometry"/></mxCell>
      <mxCell id="uc20" value="Approve Plan" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="600" width="140" height="40" as="geometry"/></mxCell>
      <mxCell id="uc21" value="Reject Plan" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="670" width="130" height="40" as="geometry"/></mxCell>

      <!-- USE CASES: Shared -->
      <mxCell id="uc22" value="View Reports" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="430" y="790" width="140" height="40" as="geometry"/></mxCell>
      <mxCell id="uc23" value="View Dashboard" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="630" y="790" width="155" height="40" as="geometry"/></mxCell>

      <!-- === ASSOCIATIONS: Admin === -->
      <mxCell id="e1" style="html=1;endArrow=none;" edge="1" source="ac_admin" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e2" style="html=1;endArrow=none;" edge="1" source="ac_admin" target="uc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e3" style="html=1;endArrow=none;" edge="1" source="ac_admin" target="uc4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e4" style="html=1;endArrow=none;" edge="1" source="ac_admin" target="uc5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e5" style="html=1;endArrow=none;" edge="1" source="ac_admin" target="uc6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e6" style="html=1;endArrow=none;" edge="1" source="ac_admin" target="uc22" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- === ASSOCIATIONS: PE === -->
      <mxCell id="e10" style="html=1;endArrow=none;" edge="1" source="ac_pe" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e11" style="html=1;endArrow=none;" edge="1" source="ac_pe" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e12" style="html=1;endArrow=none;" edge="1" source="ac_pe" target="uc7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e13" style="html=1;endArrow=none;" edge="1" source="ac_pe" target="uc10" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e14" style="html=1;endArrow=none;" edge="1" source="ac_pe" target="uc12" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e15" style="html=1;endArrow=none;" edge="1" source="ac_pe" target="uc14" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e16" style="html=1;endArrow=none;" edge="1" source="ac_pe" target="uc22" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e17" style="html=1;endArrow=none;" edge="1" source="ac_pe" target="uc23" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- === ASSOCIATIONS: PM === -->
      <mxCell id="e20" style="html=1;endArrow=none;" edge="1" source="ac_pm" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e21" style="html=1;endArrow=none;" edge="1" source="ac_pm" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e22" style="html=1;endArrow=none;" edge="1" source="ac_pm" target="uc18" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e23" style="html=1;endArrow=none;" edge="1" source="ac_pm" target="uc19" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e24" style="html=1;endArrow=none;" edge="1" source="ac_pm" target="uc20" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e25" style="html=1;endArrow=none;" edge="1" source="ac_pm" target="uc21" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e26" style="html=1;endArrow=none;" edge="1" source="ac_pm" target="uc22" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e27" style="html=1;endArrow=none;" edge="1" source="ac_pm" target="uc23" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- === ASSOCIATIONS: YOLO AI === -->
      <mxCell id="e30" style="html=1;endArrow=none;" edge="1" source="ac_ai" target="uc15" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e31" style="html=1;endArrow=none;" edge="1" source="ac_ai" target="uc16" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="e32" style="html=1;endArrow=none;" edge="1" source="ac_ai" target="uc17" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- === INCLUDE / EXTEND (dashed) === -->
      <!-- Create Plan «include» Upload Photo -->
      <mxCell id="inc1" value="«include»" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;" edge="1" source="uc7" target="uc8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <!-- Create Plan «include» Fill Metadata -->
      <mxCell id="inc2" value="«include»" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;" edge="1" source="uc7" target="uc9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <!-- Create Plan «include» Detect Joints -->
      <mxCell id="inc3" value="«include»" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;" edge="1" source="uc7" target="uc15" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <!-- Detect Joints «include» Generate Boxes -->
      <mxCell id="inc4" value="«include»" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;" edge="1" source="uc15" target="uc16" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <!-- Generate Boxes «include» Calculate Cost -->
      <mxCell id="inc5" value="«include»" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;" edge="1" source="uc16" target="uc17" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <!-- Adjust Boxes «extend» Review AI Detection -->
      <mxCell id="ext1" value="«extend»" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;" edge="1" source="uc11" target="uc10" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <!-- Revise Plan «extend» Reject Plan -->
      <mxCell id="ext2" value="«extend»" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;" edge="1" source="uc14" target="uc21" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    </root></mxGraphModel>
  </diagram>
</mxfile>
